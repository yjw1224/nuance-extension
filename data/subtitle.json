  "events": [ {
    "tStartMs": 1201,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "-We are so excited.\nI am so excited."
    } ]
  }, {
    "tStartMs": 2402,
    "dDurationMs": 2036,
    "segs": [ {
      "utf8": "Welcome to the show."
    } ]
  }, {
    "tStartMs": 4438,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "We have to talk about this\nphenomenon,"
    } ]
  }, {
    "tStartMs": 7007,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "\"KPop Demon Hunters.\""
    } ]
  }, {
    "tStartMs": 8542,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "-You are...\n-[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 11612,
    "dDurationMs": 4604,
    "segs": [ {
      "utf8": "...the singing voices of\nthe three main characters here."
    } ]
  }, {
    "tStartMs": 16216,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "Yeah, that's you. Yeah.\n-Yeah."
    } ]
  }, {
    "tStartMs": 19019,
    "dDurationMs": 5172,
    "segs": [ {
      "utf8": "-You're a K-Pop group called\nHuntr/x that also fights demons."
    } ]
  }, {
    "tStartMs": 24191,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-Mm-hmm.\n-Yeah."
    } ]
  }, {
    "tStartMs": 25559,
    "dDurationMs": 4671,
    "segs": [ {
      "utf8": "-Great.\n-This has been a phenomenon."
    } ]
  }, {
    "tStartMs": 30230,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "Congratulations\non every single thing."
    } ]
  }, {
    "tStartMs": 32833,
    "dDurationMs": 2369,
    "segs": [ {
      "utf8": "I'm so honored\nto have you here."
    } ]
  }, {
    "tStartMs": 35202,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "I know you made\nan appearance on"
    } ]
  }, {
    "tStartMs": 36570,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "\"Saturday Night Live\"\nthis past weekend."
    } ]
  }, {
    "tStartMs": 38839,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "-Yeah.\n[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 43243,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "-The dream.\n[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 47915,
    "dDurationMs": 3603,
    "segs": [ {
      "utf8": "-What has it been like?"
    } ]
  }, {
    "tStartMs": 51518,
    "dDurationMs": 3303,
    "segs": [ {
      "utf8": "How's it feeling right now?\nWhat are you feeling like?"
    } ]
  }, {
    "tStartMs": 54821,
    "dDurationMs": 1569,
    "segs": [ {
      "utf8": "-Oh, my gosh. Surreal. Wow."
    } ]
  }, {
    "tStartMs": 56390,
    "dDurationMs": 3603,
    "segs": [ {
      "utf8": "-We try to come up with new\nadjectives every time."
    } ]
  }, {
    "tStartMs": 59993,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "-Like...delicious.\n-Scrumptious."
    } ]
  }, {
    "tStartMs": 62329,
    "dDurationMs": 2035,
    "segs": [ {
      "utf8": "-Yeah, scrumptious.\n-Stunning."
    } ]
  }, {
    "tStartMs": 64364,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "-Scrumptious.\nDelicious is good."
    } ]
  }, {
    "tStartMs": 65999,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "-Stunning.\n-Stunning, yeah."
    } ]
  }, {
    "tStartMs": 68068,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-Bonkers.\n-Bonkers."
    } ]
  }, {
    "tStartMs": 69436,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "-Did you ever think you\nwould do \"Saturday Night Live\"?"
    } ]
  }, {
    "tStartMs": 71538,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "-No. That's crazy.\nIt's so insane."
    } ]
  }, {
    "tStartMs": 74975,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "-Yeah. It's wild."
    } ]
  }, {
    "tStartMs": 76176,
    "dDurationMs": 2636,
    "segs": [ {
      "utf8": "-A literal dream come true,\nI think."
    } ]
  }, {
    "tStartMs": 78812,
    "dDurationMs": 3237,
    "segs": [ {
      "utf8": "The 10-year-old in me\njust came to life being on set."
    } ]
  }, {
    "tStartMs": 82049,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "It just -- Like Audrey said,"
    } ]
  }, {
    "tStartMs": 83984,
    "dDurationMs": 2202,
    "segs": [ {
      "utf8": "it kind of reminded us\nof being, like, in theater camp."
    } ]
  }, {
    "tStartMs": 86186,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "-Yeah, it did."
    } ]
  }, {
    "tStartMs": 87688,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "-Oh, because it is live theater,\nbasically."
    } ]
  }, {
    "tStartMs": 89990,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "-Literally.\n-Yeah."
    } ]
  }, {
    "tStartMs": 91158,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "-I mean,\nit's been such a giant thing."
    } ]
  }, {
    "tStartMs": 92860,
    "dDurationMs": 3303,
    "segs": [ {
      "utf8": "It's been streamed\nover 362 million times."
    } ]
  }, {
    "tStartMs": 96163,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "-For real?\n-Really?"
    } ]
  }, {
    "tStartMs": 98432,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "-Around the world.\n-Wow!"
    } ]
  }, {
    "tStartMs": 101001,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "-Soundtrack is breaking\nall sorts of records."
    } ]
  }, {
    "tStartMs": 103804,
    "dDurationMs": 2135,
    "segs": [ {
      "utf8": "I want to read some of these\nright here, if you don't mind."
    } ]
  }, {
    "tStartMs": 105939,
    "dDurationMs": 3604,
    "segs": [ {
      "utf8": "The soundtrack has been on\nthe Billboard 200 for 15 weeks."
    } ]
  }, {
    "tStartMs": 109543,
    "dDurationMs": 3103,
    "segs": [ {
      "utf8": "\"Golden\" was number 1\non the Billboard Hot 100"
    } ]
  }, {
    "tStartMs": 112646,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "for eight weeks,"
    } ]
  }, {
    "tStartMs": 114348,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "and longest-running\nnumber 1 of the year"
    } ]
  }, {
    "tStartMs": 115349,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "on Global 200 Singles chart."
    } ]
  }, {
    "tStartMs": 117651,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "\"Golden\" is the first number-1"
    } ]
  }, {
    "tStartMs": 119753,
    "dDurationMs": 3771,
    "segs": [ {
      "utf8": "female K-Pop song\nin the history of the Hot 100."
    } ]
  }, {
    "tStartMs": 123524,
    "dDurationMs": 2902,
    "segs": [ {
      "utf8": "And you are the longest-running\nnumber-1 girl group"
    } ]
  }, {
    "tStartMs": 126426,
    "dDurationMs": 3404,
    "segs": [ {
      "utf8": "of the century on Hot 100,\nbeating Destiny's Child."
    } ]
  }, {
    "tStartMs": 129830,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "-Oh, my gosh.\n-[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 132633,
    "dDurationMs": 1968,
    "segs": [ {
      "utf8": "Insane."
    } ]
  }, {
    "tStartMs": 137738,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "-Yes!\n-Thank you."
    } ]
  }, {
    "tStartMs": 139339,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "-Thank you."
    } ]
  }, {
    "tStartMs": 141208,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "Wow.\n-That's insane."
    } ]
  }, {
    "tStartMs": 144178,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "-What have been some\nof the best reactions"
    } ]
  }, {
    "tStartMs": 146046,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "that you've gotten so far?"
    } ]
  }, {
    "tStartMs": 147514,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "-[ Sighs ] Man.\nYeah, go ahead."
    } ]
  }, {
    "tStartMs": 150951,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "-Oh, well, for me,\nit was just --"
    } ]
  }, {
    "tStartMs": 152486,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "I went to Korea recently,\nand I had a mask and a hat on,"
    } ]
  }, {
    "tStartMs": 156490,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "but they recognized me somehow,"
    } ]
  }, {
    "tStartMs": 159059,
    "dDurationMs": 3237,
    "segs": [ {
      "utf8": "and the whole cabin crew\ncame through to my seat"
    } ]
  }, {
    "tStartMs": 162296,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "and said hello."
    } ]
  }, {
    "tStartMs": 163997,
    "dDurationMs": 3571,
    "segs": [ {
      "utf8": "And also the pilot,\nboth of them."
    } ]
  }, {
    "tStartMs": 167568,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "-Hopefully not at the same time.\n-No."
    } ]
  }, {
    "tStartMs": 169570,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "-Okay, alright."
    } ]
  }, {
    "tStartMs": 170838,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "One was flying the plane,\nand one was saying hi."
    } ]
  }, {
    "tStartMs": 173240,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "-I was like, \"Wait.\nWho's flying the plane?\""
    } ]
  }, {
    "tStartMs": 174474,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "But, yeah, it was amazing.\n-Autopilot."
    } ]
  }, {
    "tStartMs": 176543,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "-How about you?"
    } ]
  }, {
    "tStartMs": 178478,
    "dDurationMs": 3571,
    "segs": [ {
      "utf8": "-Honestly, I went to Korea,\nas well, a few weeks after"
    } ]
  }, {
    "tStartMs": 182049,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "the film was\nreally taking off,"
    } ]
  }, {
    "tStartMs": 183750,
    "dDurationMs": 2636,
    "segs": [ {
      "utf8": "and I got off\nat Dongdaemun Station,"
    } ]
  }, {
    "tStartMs": 186386,
    "dDurationMs": 5072,
    "segs": [ {
      "utf8": "and this cute little grandpa\nwas doing a street performance"
    } ]
  }, {
    "tStartMs": 191458,
    "dDurationMs": 4972,
    "segs": [ {
      "utf8": "of \"Golden,\" like, on this\ntraditional Korean instrument."
    } ]
  }, {
    "tStartMs": 196430,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "He was so swagged out.\nLike, his outfit was fire."
    } ]
  }, {
    "tStartMs": 200100,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "And I had to literally do\na double take, because,"
    } ]
  }, {
    "tStartMs": 202769,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "you know,\nin Korean culture,"
    } ]
  }, {
    "tStartMs": 204638,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "I think it's\nespecially impressive"
    } ]
  }, {
    "tStartMs": 207708,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "if an elderly is -- a person of\nelderly is impressed with you,"
    } ]
  }, {
    "tStartMs": 212045,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "because, you know,\nyou can get into an Ivy League,"
    } ]
  }, {
    "tStartMs": 213881,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "you can graduate top\nof your class,"
    } ]
  }, {
    "tStartMs": 215582,
    "dDurationMs": 2870,
    "segs": [ {
      "utf8": "it's just like, \"Oh, yeah,\nthat makes sense."
    } ]
  }, {
    "tStartMs": 218452,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "That's what\nit should have been.\""
    } ]
  }, {
    "tStartMs": 220354,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "-They don't compliment.\nIt's really hard."
    } ]
  }, {
    "tStartMs": 221588,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-Yeah, it's really hard\nto get, like, so picky."
    } ]
  }, {
    "tStartMs": 224491,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "Yeah, they're very --\nThey have high standards."
    } ]
  }, {
    "tStartMs": 226426,
    "dDurationMs": 1202,
    "segs": [ {
      "utf8": "-Yeah."
    } ]
  }, {
    "tStartMs": 227628,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "-So for, like,\nyou know, the older people --"
    } ]
  }, {
    "tStartMs": 230631,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "-The older generation.\n-Yeah."
    } ]
  }, {
    "tStartMs": 232499,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "To embrace it\nas something different."
    } ]
  }, {
    "tStartMs": 234134,
    "dDurationMs": 1769,
    "segs": [ {
      "utf8": "-Yeah, 100%.\n-So different."
    } ]
  }, {
    "tStartMs": 235903,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "-I was going to H Mart"
    } ]
  }, {
    "tStartMs": 238005,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "the other day just\nto pick up some cup noodles,"
    } ]
  }, {
    "tStartMs": 239573,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "because I like to travel\nwith them."
    } ]
  }, {
    "tStartMs": 241241,
    "dDurationMs": 2202,
    "segs": [ {
      "utf8": "-Okay. Do love H Mart."
    } ]
  }, {
    "tStartMs": 243443,
    "dDurationMs": 2837,
    "segs": [ {
      "utf8": "-That's my favorite place\nin L.A. -- on Sixth Street."
    } ]
  }, {
    "tStartMs": 246280,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "You'll find me there,\nif you want to spot me there."
    } ]
  }, {
    "tStartMs": 248448,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "-Oh, my..."
    } ]
  }, {
    "tStartMs": 250050,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "-Actually, don't.\nThat would scare me."
    } ]
  }, {
    "tStartMs": 251952,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "I was walking in."
    } ]
  }, {
    "tStartMs": 253654,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "It was right after rehearsal,\nactually."
    } ]
  }, {
    "tStartMs": 255889,
    "dDurationMs": 5973,
    "segs": [ {
      "utf8": "And I just hear this little\n5-year-old boy singing \"Golden\""
    } ]
  }, {
    "tStartMs": 261862,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "at the top of his lungs,"
    } ]
  }, {
    "tStartMs": 264131,
    "dDurationMs": 2602,
    "segs": [ {
      "utf8": "smiling ear-to-ear,\nholding his mom's hand."
    } ]
  }, {
    "tStartMs": 266733,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "And he's like...\n♪ Born to be ♪"
    } ]
  }, {
    "tStartMs": 268635,
    "dDurationMs": 2636,
    "segs": [ {
      "utf8": "And I --\n-Oh, wow. Hey!"
    } ]
  }, {
    "tStartMs": 271271,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-I whipped my head\nand I was like,"
    } ]
  }, {
    "tStartMs": 274174,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "\"There is no way this child\nchose this --\""
    } ]
  }, {
    "tStartMs": 277611,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "Of all songs to sing,\nhe chose \"Golden.\""
    } ]
  }, {
    "tStartMs": 280147,
    "dDurationMs": 3503,
    "segs": [ {
      "utf8": "And I think it's one thing\nto hear our song on the radio,"
    } ]
  }, {
    "tStartMs": 283650,
    "dDurationMs": 3137,
    "segs": [ {
      "utf8": "but to hear it come out of\na child?"
    } ]
  }, {
    "tStartMs": 286787,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "-Live.\n-Live."
    } ]
  }, {
    "tStartMs": 288055,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "-In H Mart?\n-In H Mart? My favorite place?"
    } ]
  }, {
    "tStartMs": 292059,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "-In H -- Yeah, of course.\n-In the kimchi section."
    } ]
  }, {
    "tStartMs": 293994,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "-In the kimchi section.\n-I just cried at H Mart."
    } ]
  }, {
    "tStartMs": 297564,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "-My kids --\nYou cried at H Mart?"
    } ]
  }, {
    "tStartMs": 300234,
    "dDurationMs": 2435,
    "segs": [ {
      "utf8": "My kids were singing it."
    } ]
  }, {
    "tStartMs": 302669,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "In fact, this past weekend,\nwe were playing a game,"
    } ]
  }, {
    "tStartMs": 304738,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "a board game,\nand my daughter sang it"
    } ]
  }, {
    "tStartMs": 306273,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "for about an hour straight."
    } ]
  }, {
    "tStartMs": 308041,
    "dDurationMs": 2436,
    "segs": [ {
      "utf8": "-Wow!\n-Yeah. And I didn't mind it."
    } ]
  }, {
    "tStartMs": 310477,
    "dDurationMs": 2636,
    "segs": [ {
      "utf8": "I loved it. I actually loved it.\nAnd she kept going."
    } ]
  }, {
    "tStartMs": 313113,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "♪ Going up, up, up ♪"
    } ]
  }, {
    "tStartMs": 314915,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "And then she was trying\nto hit the next octave."
    } ]
  }, {
    "tStartMs": 315916,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "♪ Up ♪"
    } ]
  }, {
    "tStartMs": 317317,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "I don't even know how you do\nthat, but we'll hear it tonight."
    } ]
  }, {
    "tStartMs": 319152,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "-Yes.\n-It's amazing."
    } ]
  }, {
    "tStartMs": 321021,
    "dDurationMs": 3103,
    "segs": [ {
      "utf8": "Your vocal range is impossible.\nIt's so good."
    } ]
  }, {
    "tStartMs": 324124,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "It is such a great song."
    } ]
  }, {
    "tStartMs": 325626,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "I watched it and I go,\n\"Oh, this will be fun."
    } ]
  }, {
    "tStartMs": 327294,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "I'll watch it\nwith my daughters.\""
    } ]
  }, {
    "tStartMs": 329162,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "And I go, \"Hey, this music is\nactually phenomenal."
    } ]
  }, {
    "tStartMs": 331665,
    "dDurationMs": 3537,
    "segs": [ {
      "utf8": "This is great.\"\nI got so into it. I loved it."
    } ]
  }, {
    "tStartMs": 335202,
