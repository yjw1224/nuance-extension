{
  "manifest_version": 3,
  "name": "Nuance",
  "version": "0.1",

  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:3000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "translation.json"
      ],
      "matches": [
        "<all_urls>"
      ]
    },
    {
      "resources": [
        "fonts/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}